---
/**
 * FollowUsCard — 关注半百观AI 多平台卡片
 * 用于文章末尾、首页等位置引导用户关注各平台
 */
const platforms = [
  { name: '微信公众号', icon: '💬', tip: '深度图文、AI 工具测评' },
  { name: '视频号', icon: '🎥', tip: '1-3 分钟 AI 教程' },
  { name: '抖音', icon: '🎵', tip: 'AI 效率提升短视频' },
  { name: '今日头条', icon: '📰', tip: 'AI 实践分享' },
  { name: '西瓜视频', icon: '🍉', tip: 'AI 项目实操' },
  { name: 'B 站', icon: '📺', tip: 'AI 技术深度解析' },
  { name: '小红书', icon: '📕', tip: 'AI 工具推荐清单' },
];
---

<div class="follow-us-card">
  <div class="follow-us-header">
    <span class="follow-us-icon">🔔</span>
    <div>
      <h3>关注「半百观AI」</h3>
      <p>50 岁视角看 AI 工具落地实践，全平台同步更新</p>
    </div>
  </div>
  <div class="follow-us-platforms">
    {platforms.map((p) => (
      <div class="platform-item">
        <span class="platform-icon">{p.icon}</span>
        <div class="platform-info">
          <span class="platform-name">{p.name}</span>
          <span class="platform-tip">{p.tip}</span>
        </div>
        <span class="platform-badge">半百观AI</span>
      </div>
    ))}
  </div>
  <p class="follow-us-hint">🔍 在各平台搜索"半百观AI"即可找到我们</p>
</div>

<style>
  .follow-us-card {
    background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
    border: 1px solid #c7d2fe;
    border-radius: 16px;
    padding: 24px;
    margin: 32px 0;
  }

  .follow-us-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 20px;
  }

  .follow-us-icon {
    font-size: 28px;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .follow-us-header h3 {
    font-size: 18px;
    font-weight: 700;
    color: #1a1a2e;
    margin: 0 0 4px;
  }

  .follow-us-header p {
    font-size: 13px;
    color: #64748b;
    margin: 0;
  }

  .follow-us-platforms {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 10px;
  }

  .platform-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    transition: all 0.15s;
  }

  .platform-item:hover {
    border-color: #4f46e5;
    box-shadow: 0 2px 8px rgba(79, 70, 229, 0.1);
    transform: translateY(-1px);
  }

  .platform-icon {
    font-size: 20px;
    line-height: 1;
    flex-shrink: 0;
  }

  .platform-info {
    flex: 1;
    min-width: 0;
  }

  .platform-name {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: #1e293b;
  }

  .platform-tip {
    display: block;
    font-size: 11px;
    color: #94a3b8;
    margin-top: 2px;
  }

  .platform-badge {
    font-size: 11px;
    color: #4f46e5;
    background: #eef2ff;
    padding: 3px 8px;
    border-radius: 6px;
    font-weight: 500;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .follow-us-hint {
    text-align: center;
    font-size: 13px;
    color: #64748b;
    margin: 16px 0 0;
  }

  @media (max-width: 640px) {
    .follow-us-card {
      padding: 16px;
      margin: 24px 0;
    }

    .follow-us-platforms {
      grid-template-columns: 1fr;
    }

    .follow-us-header h3 {
      font-size: 16px;
    }
  }
</style>
