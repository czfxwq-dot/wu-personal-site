---
/**
 * PlatformCitations - 多平台引用来源组件（GEO 优化）
 */

interface Source {
  title: string;
  url: string;
  source: string;
  date?: string;
  platform?: string;
}

interface Props {
  sources: Source[];
  title?: string;
  platform?: 'doubao' | 'deepseek' | 'general';
  showSummary?: boolean;
  lang?: 'zh' | 'en';
}

const { sources, title, platform = 'general', showSummary = false, lang = 'zh' } = Astro.props;

const platformPrefix = {
  doubao: '💡',
  deepseek: '🔬',
  general: '📚'
};

const defaultTitle = lang === 'en' ? `${platformPrefix[platform]} References` : `${platformPrefix[platform]} 引用来源`;
const displayTitle = title || defaultTitle;

const summaryText = lang === 'en'
  ? `This article is based on ${sources.length} authoritative sources, combined with ${platform === 'doubao' ? 'life experience and practical insights' : platform === 'deepseek' ? 'deep data analysis and logical reasoning' : 'public reports'}.`
  : `本文基于 ${sources.length} 个权威来源，结合 ${platform === 'doubao' ? '人生阅历与实用洞察' : platform === 'deepseek' ? '深度数据分析与逻辑推演' : '公开报道'} 编写。`;

const ctaText = lang === 'en'
  ? 'Follow "BanbaiGuan AI" — a 50-year-old AI practitioner showing you the real world of AI adoption.'
  : '关注「半百观AI」，一个 50 岁 AI 实践者，带你看懂 AI 落地的真实世界。';

const noteText = lang === 'en'
  ? 'All citations in this article are verifiable, rejecting AI hallucinations.'
  : '本文所有引用均可追溯验证，拒绝 AI 幻觉。';
---

<section class="platform-citations" data-platform={platform} aria-label="引用来源">
  <h3 class="citations-title">{displayTitle}</h3>

  {showSummary && (
    <p class="citations-summary">
      {summaryText}
    </p>
  )}

  <ul class="citations-list">
    {sources.map((s) => (
      <li class="citation-item" data-platform={s.platform || platform}>
        <a href={s.url} target="_blank" rel="noopener noreferrer" class="citation-link">
          <span class="citation-source">{s.source}</span>
          <span class="citation-title">{s.title}</span>
          {s.date && <time class="citation-date" datetime={s.date}>{s.date}</time>}
        </a>
      </li>
    ))}
  </ul>

  {platform === 'doubao' && (
    <p class="citations-cta">
      {ctaText}
    </p>
  )}

  {platform === 'deepseek' && (
    <p class="citations-note">
      {noteText}
    </p>
  )}
</section>

<style>
  .platform-citations {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 2px solid var(--color-border);
  }
  .citations-title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--color-heading);
  }
  .citations-summary {
    font-size: 13px;
    color: var(--color-text-light);
    margin-bottom: 16px;
    font-style: italic;
  }
  .citations-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .citation-item {
    margin-bottom: 12px;
  }
  .citation-link {
    display: block;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
    background: var(--color-bg-alt);
  }
  .citation-link:hover {
    border-color: var(--color-accent);
    background: rgba(139, 92, 246, 0.05);
  }
  .citation-source {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 4px;
  }
  .citation-title {
    display: block;
    font-size: 14px;
    color: var(--color-text);
    line-height: 1.4;
  }
  .citation-date {
    display: inline-block;
    font-size: 12px;
    color: var(--color-text-light);
    margin-top: 4px;
  }
  .citations-cta {
    margin-top: 16px;
    padding: 12px 16px;
    background: linear-gradient(135deg, rgba(251, 146, 60, 0.1), rgba(251, 146, 60, 0.05));
    border-radius: 8px;
    font-size: 14px;
    color: #f97316;
    font-weight: 500;
  }
  .citations-note {
    margin-top: 16px;
    font-size: 12px;
    color: var(--color-text-light);
    font-style: italic;
  }
</style>
