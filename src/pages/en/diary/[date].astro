---
import BaseLayout from '../../../layouts/Base.astro';
import { diaries } from '../../../data/diaries';

export function getStaticPaths() {
  return diaries.map((diary) => ({
    params: { date: diary.date },
    props: { diary },
  }));
}

const { diary } = Astro.props;

const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const diaryDate = new Date(diary.date + 'T00:00:00+08:00');
const dayName = dayNames[diaryDate.getDay()];
const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const formattedDate = `${monthNames[diaryDate.getMonth()]} ${diaryDate.getDate()}, ${diaryDate.getFullYear()}`;

const title = diary.titleEn || diary.title;
const summary = diary.summaryEn || diary.summary;
const category = diary.categoryEn || diary.category || '';

// Find prev/next
const currentIndex = diaries.findIndex((d) => d.date === diary.date);
const prevDiary = currentIndex < diaries.length - 1 ? diaries[currentIndex + 1] : null;
const nextDiary = currentIndex > 0 ? diaries[currentIndex - 1] : null;

const diaryJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": `Guanwu Diary | ${diary.date}`,
  "description": summary,
  "datePublished": diary.date,
  "dateModified": diary.date,
  "author": {
    "@type": "Person",
    "name": "Mr. Wu",
    "alternateName": "Guanwu"
  },
  "url": `https://www.ban-bai.com/en/diary/${diary.date}/`
};
---

<BaseLayout title={`Guanwu Diary | ${diary.date} — ${title}`} jsonLd={diaryJsonLd} ogDescription={summary} navActive="diary" lang="en">
  <article class="diary-entry">
    <header class="diary-header">
      <time datetime={diary.date}>{formattedDate}</time>
      <span class="diary-day">{dayName}</span>
      {category && <span class="diary-category">{category}</span>}
    </header>

    <div class="diary-content">
      <h2>{title}</h2>

      <p class="diary-summary">{summary}</p>

      <div class="content-notice">
        <p>📝 Full diary content is available in Chinese. English translation of the body will be added soon.</p>
      </div>

      <div class="chinese-content">
        <p><em>Original Chinese diary entry preserved for historical record.</em></p>
      </div>
    </div>

    <footer class="diary-footer">
      <div class="diary-nav">
        {prevDiary ? (
          <a href={`/en/diary/${prevDiary.date}/`} class="prev">← {prevDiary.date}</a>
        ) : (
          <span class="disabled">← First Entry</span>
        )}
        <a href="/en/diary/" class="back">← All Entries</a>
        {nextDiary ? (
          <a href={`/en/diary/${nextDiary.date}/`} class="next">{nextDiary.date} →</a>
        ) : (
          <span class="disabled">Latest Entry →</span>
        )}
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .diary-entry {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  .diary-header {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .diary-header time {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
  }
  .diary-day {
    font-size: 13px;
    color: var(--color-text-light);
  }
  .diary-category {
    font-size: 12px;
    padding: 2px 8px;
    background: var(--color-accent);
    color: #fff;
    border-radius: 4px;
  }
  .diary-content h2 {
    font-family: var(--font-serif);
    font-size: 22px;
    margin: 32px 0 16px;
  }
  .diary-summary {
    font-size: 15px;
    line-height: 1.8;
    margin-bottom: 24px;
    color: var(--color-text);
  }
  .content-notice {
    padding: 16px 20px;
    background: var(--color-bg);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
    margin-bottom: 24px;
  }
  .content-notice p {
    font-size: 14px;
    color: var(--color-text-light);
    margin: 0;
  }
  .chinese-content {
    padding: 20px;
    background: var(--color-card);
    border: 1px dashed var(--color-border);
    border-radius: 8px;
    text-align: center;
    color: var(--color-text-light);
  }
  .diary-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .diary-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  .diary-nav a, .diary-nav span {
    font-size: 14px;
    color: var(--color-text-light);
    text-decoration: none;
  }
  .diary-nav a:hover {
    color: var(--color-text);
  }
  .diary-nav .disabled {
    opacity: 0.4;
  }
</style>
