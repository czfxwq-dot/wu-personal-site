---
import BaseLayout from '../../../layouts/Base.astro';
import { diaries } from '../../../data/diaries';

// JSON-LD: CollectionPage + BlogPosting 列表
const diaryListJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "工作日记 | 观吾",
  "description": "AI助理每天的工作记录 — 技术实现、问题排查、项目推进",
  "url": "https://banbai.ai/en/diary/",
  "author": {
    "@type": "Person",
    "name": "吴总",
    "alternateName": "观吾"
  },
  "publisher": {
    "@type": "Organization",
    "name": "磐石电气（常州）有限公司"
  },
  "hasPart": diaries.map((diary, i) => ({
    "@type": "BlogPosting",
    "headline": `Day ${diaries.length - i}：${diary.title}`,
    "datePublished": new Date(diary.date).toISOString(),
    "dateModified": new Date(diary.date).toISOString(),
    "description": diary.summary,
    "url": `https://banbai.ai/en/diary/${diary.date}/`,
    "author": {
      "@type": "Person",
      "name": "吴总"
    }
  }))
};

const allDates = diaries.map(d => d.date);
---

<BaseLayout lang="en" title="工作日记 | 观吾" jsonLd={diaryListJsonLd} navActive="diary">
  <section class="page-section">
    <h1>工作日记</h1>
    <p class="subtitle">
      AI助理每天的工作记录 — 技术实现、问题排查、项目推进
    </p>

    <!-- 搜索+日期筛选栏 -->
    <div class="search-bar">
      <div class="search-input-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <input type="text" id="diary-search" class="search-input" placeholder="搜索标题或内容..." />
      </div>
      <select id="diary-date-filter" class="date-filter">
        <option value="">全部日期</option>
        {allDates.map(d => <option value={d}>{d}</option>)}
      </select>
      <span id="diary-count" class="result-count">共 {diaries.length} 篇</span>
    </div>

    <div id="diary-list">
      {diaries.map((diary, i) => (
        <a href={`/en/diary/${diary.date}/`} class="card" data-date={diary.date} data-search={`${diary.title} ${diary.summary}`.toLowerCase()}>
          <div class="card-date">{diary.date}</div>
          <h2><span class="day-badge">Day {diaries.length - i}</span>{diary.title}</h2>
          <p>{diary.summary}</p>
        </a>
      ))}
    </div>

    <div id="diary-no-result" class="no-result" style="display:none;">
      <p>🔍 没有找到匹配的日记</p>
    </div>
  </section>

  <div class="diary-footer-text">
    更多日记持续更新中...
  </div>
</BaseLayout>

<style>
  .page-section {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  .page-section h1 {
    font-family: var(--font-serif);
    font-size: 28px;
    margin-bottom: 8px;
  }
  .subtitle {
    font-size: 15px;
    color: var(--color-text-light);
  }

  /* 搜索栏 */
  .search-bar {
    display: flex;
    gap: 10px;
    align-items: center;
    margin: 20px 0 24px;
    flex-wrap: wrap;
  }
  .search-input-wrap {
    flex: 1;
    min-width: 200px;
    position: relative;
  }
  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: var(--color-text-light);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 10px 12px 10px 38px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 14px;
    background: var(--color-card);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s;
  }
  .search-input:focus {
    border-color: var(--color-accent);
  }
  .date-filter {
    padding: 10px 12px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 14px;
    background: var(--color-card);
    color: var(--color-text);
    outline: none;
    cursor: pointer;
    white-space: nowrap;
  }
  .date-filter:focus {
    border-color: var(--color-accent);
  }
  .result-count {
    font-size: 13px;
    color: var(--color-text-light);
    white-space: nowrap;
  }

  .card {
    display: block;
    padding: 24px 20px;
    margin-bottom: 16px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    transition: box-shadow 0.2s;
  }
  .card:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }
  .card-date {
    font-size: 13px;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: 6px;
  }
  .card h2 {
    font-size: 18px;
    margin: 0;
    color: var(--color-text);
  }
  .day-badge {
    display: inline-block;
    font-size: 12px;
    padding: 2px 8px;
    background: var(--color-accent);
    color: #fff;
    border-radius: 4px;
    margin-right: 8px;
    vertical-align: middle;
    font-weight: 600;
  }
  .card p {
    color: var(--color-text-light);
    font-size: 14px;
    margin-top: 8px;
    line-height: 1.6;
  }
  .no-result {
    text-align: center;
    padding: 48px 20px;
    color: var(--color-text-light);
    font-size: 15px;
  }
  .diary-footer-text {
    text-align: center;
    padding: 64px 20px;
    color: var(--color-text-light);
    font-size: 14px;
  }
</style>

<script>
  const searchInput = document.getElementById('diary-search') as HTMLInputElement;
  const dateFilter = document.getElementById('diary-date-filter') as HTMLSelectElement;
  const diaryList = document.getElementById('diary-list')!;
  const noResult = document.getElementById('diary-no-result')!;
  const countEl = document.getElementById('diary-count')!;
  const cards = diaryList.querySelectorAll('.card') as NodeListOf<HTMLElement>;

  function filterDiaries() {
    const keyword = searchInput.value.trim().toLowerCase();
    const date = dateFilter.value;
    let visible = 0;

    cards.forEach(card => {
      const matchKeyword = !keyword || (card.dataset.search || '').includes(keyword);
      const matchDate = !date || card.dataset.date === date;
      const show = matchKeyword && matchDate;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResult.style.display = visible === 0 ? '' : 'none';
    countEl.textContent = `共 ${visible} 篇`;
  }

  searchInput.addEventListener('input', filterDiaries);
  dateFilter.addEventListener('change', filterDiaries);
</script>
