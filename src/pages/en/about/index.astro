---
import BaseLayout from '../../../layouts/Base.astro';

const aboutJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "name": "About | Guanwu",
  "description": "Mr. Wu's personal profile — Co-founder of MonolithIoT, AIoT practitioner, BanbaiGuan AI founder",
  "url": "https://ban-bai.com/en/about/",
  "inLanguage": "en",
  "mainEntity": {
    "@type": "Person",
    "name": "Mr. Wu",
    "alternateName": "Guanwu",
    "image": "https://ban-bai.com/avatar.jpg",
    "jobTitle": "Co-founder",
    "worksFor": {
      "@type": "Organization",
      "name": "MonolithIoT (Changzhou) Co., Ltd.",
      "url": "https://www.monolithiot.com"
    },
    "description": "At 50, skilled in structured thinking and first-principles reasoning. Expert in AI applications, brand management, and new media operations.",
    "knowsAbout": ["AI Applications", "AIoT", "Digital Inventory Management", "Brand Management", "New Media Operations"],
    "url": "https://ban-bai.com/en/about/",
    "sameAs": [
      "https://ban-bai.com"
    ]
  }
};
---

<BaseLayout lang="en" title="About | Guanwu" jsonLd={aboutJsonLd} navActive="about">
  <section class="page-section">
    <h1>About</h1>

    <div class="about-section">
      <div class="section-title">Guanwu</div>
      <p class="about-text">
        Pen name: "Guanwu" (观吾 — reflect on oneself).<br />
        Co-founder of MonolithIoT (Changzhou) Co., Ltd.<br />
        Focused on digital smart inventory management AIoT products and solutions.<br />
        Founder of BanbaiGuan AI new media brand.
      </p>
      <p class="about-text">
        Skilled in structured thinking and first-principles reasoning.<br />
        Expert in AI applications, brand management, and new media operations.<br />
        What I'm doing now: using AI to turn ideas into reality.
      </p>
    </div>

    <div class="about-section">
      <div class="section-title">MonolithIoT (Changzhou) Co., Ltd.</div>
      <p class="about-text">
        National high-tech enterprise, specializing in digital intelligence solutions.
        MonolithIoT positions itself as an AI scenario solutions provider, built on three core technologies:
        multi-sensor fusion, AI-powered storage middleware, and multimodal algorithms.
        The smart work order system serves as the central hub, combined with AI prediction, visual monitoring,
        and intelligent action control — transforming complex business requirements into standardized,
        actionable, and traceable digital tasks across the entire industrial chain.
      </p>
      <p class="about-text-light">
        Two core brands — MonolithIoT and Beirong — serve industrial and retail sectors,
        providing digital solutions for State Grid, Huawei, SF Express, DHL, and other leading enterprises.
      </p>
      <p class="about-links">
        Company website: <a href="https://www.monolithiot.com/" target="_blank">monolithiot.com</a> ｜
        YouTube: <a href="https://www.youtube.com/channel/UC6x3JFjaUw3nMOen2PXDtsw" target="_blank">MonolithIoT</a>
      </p>
      <div class="about-qr-wrapper">
        <img src="/company-qr.png" alt="MonolithIoT Social Media" />
      </div>
    </div>


    <div class="about-section">
      <div class="section-title">About This Website</div>
      <p class="about-text">
        This website was built by me and my AI assistant, together.<br />
        I handle direction and content; AI handles technology and implementation.<br />
        From product design to code development — no frontend engineer involved.
      </p>
    </div>

  </section>
</BaseLayout>

<style>
  .about-section { margin-bottom: 48px; }
  .about-text { font-size: 16px; line-height: 1.9; margin-bottom: 24px; }
  .about-text-light { font-size: 15px; line-height: 1.8; color: var(--color-text-light); margin-bottom: 16px; }
  .about-links { font-size: 14px; line-height: 1.8; color: var(--color-text-light); margin-bottom: 24px; }
  .about-links a { color: var(--color-accent); text-decoration: underline; font-weight: 500; }
  .about-qr-wrapper { text-align: center; }
  .about-qr-wrapper img { max-width: 400px; width: 100%; height: auto; border-radius: 12px; }
</style>
