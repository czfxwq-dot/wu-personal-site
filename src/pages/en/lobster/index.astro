---
import BaseLayout from '../../../layouts/Base.astro';

const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Cloud Banbai Crayfish — Business Inquiry",
  "description": "Cloud Banbai Crayfish business consultation, product ordering, partnership, and after-sales support",
  "url": "https://ban-bai.com/en/lobster/",
  "inLanguage": "en"
};
---

<BaseLayout lang="en" jsonLd={pageJsonLd}>
  <section class="hero">
    <div class="container">
      <span class="hero-tag">🦞 Cloud Banbai Crayfish</span>
      <h1>
        Cloud Banbai Crayfish
        <span>Fresh · Authentic · Delicious</span>
      </h1>
      <p class="subtitle">
        Click the 🦞 button in the corner to consult our business advisor<br />
        Product ordering, partnership, after-sales — all online
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">Our Services</div>

      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🍤</div>
          <h3>Product Ordering</h3>
          <p>Multiple flavors: spicy, garlic, thirteen-spice... delivered fresh to your door</p>
          <a href="#" class="service-link" onclick="openLobsterChat(event, 'I want to order crayfish, what flavors are available?')">Order Online →</a>
        </div>

        <div class="service-card">
          <div class="service-icon">🤝</div>
          <h3>Partnership</h3>
          <p>Mature business model, complete supply chain support, low-barrier entrepreneurship</p>
          <a href="#" class="service-link" onclick="openLobsterChat(event, 'I want to learn about partnership opportunities')">Learn More →</a>
        </div>

        <div class="service-card">
          <div class="service-icon">🚚</div>
          <h3>Cold Chain Delivery</h3>
          <p>Full cold-chain freshness, same-day local delivery, 48-hour nationwide shipping</p>
          <a href="#" class="service-link" onclick="openLobsterChat(event, 'What is your delivery coverage and timeline?')">Check Delivery →</a>
        </div>

        <div class="service-card">
          <div class="service-icon">📋</div>
          <h3>After-Sales Support</h3>
          <p>7-day no-reason return, quality guaranteed, 24/7 online customer service</p>
          <a href="#" class="service-link" onclick="openLobsterChat(event, 'I need after-sales support')">Contact Support →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">Our Story</div>
      <div class="brand-story">
        <h2>Cloud Banbai Crayfish</h2>
        <p>Driven by a commitment to quality, every crayfish is carefully selected to ensure freshness, safety, and taste. We strive to deliver the finest crayfish dining experience.</p>
        <div class="brand-stats">
          <div class="stat">
            <span class="stat-number">100%</span>
            <span class="stat-label">Live Crayfish</span>
          </div>
          <div class="stat">
            <span class="stat-number">24h</span>
            <span class="stat-label">Online Support</span>
          </div>
          <div class="stat">
            <span class="stat-number">7 Days</span>
            <span class="stat-label">Free Returns</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Chat CTA -->
  <section class="page-section chat-cta">
    <div class="container">
      <div class="cta-card">
        <h2>💬 Need Help?</h2>
        <p>Click the 🦞 button in the corner to chat with our AI business advisor</p>
        <p class="cta-hint">Supports product inquiry, ordering guidance, partnership, and after-sales</p>
      </div>
    </div>
  </section>


</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 48px 0 32px;
    background: linear-gradient(135deg, #fef2f2 0%, #fff 100%);
  }
  .hero-tag {
    display: inline-block;
    font-size: 14px;
    padding: 4px 16px;
    background: #fee2e2;
    color: #dc2626;
    border-radius: 20px;
    margin-bottom: 16px;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #1a1a2e;
  }
  .hero h1 span {
    display: block;
    font-size: 16px;
    font-weight: 400;
    color: #dc2626;
    margin-top: 4px;
  }
  .subtitle {
    font-size: 16px;
    color: #6b7280;
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-top: 16px;
  }

  .service-card {
    background: white;
    border: 1px solid #fecaca;
    border-radius: 16px;
    padding: 24px;
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(220, 38, 38, 0.12);
  }
  .service-icon {
    font-size: 40px;
    margin-bottom: 12px;
  }
  .service-card h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
    color: #1a1a2e;
  }
  .service-card p {
    font-size: 14px;
    color: #6b7280;
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .service-link {
    display: inline-block;
    font-size: 14px;
    color: #dc2626;
    text-decoration: none;
    font-weight: 500;
  }
  .service-link:hover {
    text-decoration: underline;
  }

  .brand-story {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }
  .brand-story h2 {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 12px;
    color: #dc2626;
  }
  .brand-story p {
    font-size: 16px;
    color: #4b5563;
    line-height: 1.7;
  }
  .brand-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-top: 24px;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stat-number {
    font-size: 28px;
    font-weight: 700;
    color: #dc2626;
  }
  .stat-label {
    font-size: 13px;
    color: #6b7280;
    margin-top: 4px;
  }

  .chat-cta {
    text-align: center;
  }
  .cta-card {
    background: linear-gradient(135deg, #fee2e2 0%, #fff 100%);
    border-radius: 16px;
    padding: 32px;
    max-width: 500px;
    margin: 0 auto;
  }
  .cta-card h2 {
    font-size: 22px;
    margin-bottom: 8px;
    color: #1a1a2e;
  }
  .cta-card p {
    font-size: 15px;
    color: #4b5563;
    margin-bottom: 4px;
  }
  .cta-hint {
    font-size: 13px;
    color: #9ca3af;
  }

  @media (max-width: 640px) {
    .brand-stats {
      gap: 20px;
    }
    .stat-number {
      font-size: 22px;
    }
  }
</style>

<script is:inline>
  function openLobsterChat(event, message) {
    event.preventDefault();
    var toggleBtn = document.getElementById('chat-toggle-btn');
    if (toggleBtn) {
      toggleBtn.click();
      setTimeout(function() {
        var input = document.getElementById('chat-input');
        var sendBtn = document.getElementById('chat-send-btn');
        if (input && sendBtn) {
          input.value = message;
          input.dispatchEvent(new Event('input'));
          setTimeout(function() {
            sendBtn.click();
          }, 300);
        }
      }, 400);
    }
  }
</script>
