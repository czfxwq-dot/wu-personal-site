---
import BaseLayout from '../../layouts/Base.astro';
import { diaries } from '../../data/diaries';
import { dailyNewsSummaries } from '../../data/ai-news-summary';
import { articles } from '../../data/articles';

const homeJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Guanwu | 50-Year-Old Using AI to Get Things Done",
  "description": "50-year-old entrepreneur uses AI to turn ideas into reality — co-founder of MonolithIoT, sharing AI tool practices, AIoT solutions, and digital smart inventory management",
  "url": "https://banbai.ai/en/",
  "isPartOf": {
    "@type": "WebSite",
    "name": "Guanwu",
    "url": "https://banbai.ai"
  },
  "about": {
    "@type": "Person",
    "name": "Mr. Wu",
    "alternateName": "Guanwu",
    "jobTitle": "Co-founder",
    "worksFor": {
      "@type": "Organization",
      "name": "MonolithIoT (Changzhou) Co., Ltd."
    }
  },
  "keywords": ["AI tools", "AI adoption", "BanbaiGuan AI", "AIoT", "digital inventory", "learn AI at 50", "AI productivity"]
};

const latest = diaries[0];
const latestSummary = dailyNewsSummaries[0];
const latestArticle = articles[0];
---

<BaseLayout jsonLd={homeJsonLd} navActive="home" lang="en">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-gradient-1"></div>
      <div class="hero-gradient-2"></div>
      <div class="hero-grain"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        <span>AI Practitioner · BanbaiGuan AI</span>
      </div>
      <h1 class="hero-title">
        At 50, I use AI<br/>to turn ideas into reality
      </h1>
      <p class="hero-subtitle">
        Co-founder of MonolithIoT · AIoT Practitioner · BanbaiGuan AI
      </p>
      <p class="hero-description">
        This is not a typical personal website.<br/>
        My AI assistant and I built it from scratch, together.<br/>
        <span style="font-size: 14px; color: var(--color-text-tertiary);">AI tool practices · Digital smart inventory management · My honest 50-year-old AI learning journey</span>
      </p>
      <div class="hero-actions">
        <a href="/en/diary/" class="btn btn-primary">Read My Diary <span class="btn-arrow">→</span></a>
        <a href="/en/about/" class="btn btn-ghost">Learn More</a>
      </div>
    </div>
    <div class="hero-scroll-hint">
      <span class="scroll-line"></span>
      <span class="scroll-text">Scroll down</span>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="content-grid">
    <div class="container">
      <div class="grid-header">
        <div class="section-title">Latest Updates</div>
        <a href="/en/diary/" class="section-more">View Full Timeline <span class="arrow">→</span></a>
      </div>
      <div class="grid-cards">
        <!-- Latest Diary -->
        <a href="/en/diary/" class="grid-card card-diary">
          <div class="card-label">
            <span class="label-icon">📓</span>
            <span class="label-text">Diary</span>
          </div>
          <div class="card-date">{latest.date}</div>
          <h3 class="card-heading">{latest.titleEn}</h3>
          <p class="card-excerpt">{latest.summaryEn}</p>
        </a>

        <!-- AI News -->
        <a href="/en/ai-news/" class="grid-card card-news">
          <div class="card-label">
            <span class="label-icon">📡</span>
            <span class="label-text">AI News</span>
          </div>
          <div class="card-date">{latestSummary.date} · {latestSummary.newsItems.length} items</div>
          <h3 class="card-heading">{latestSummary.titleEn}</h3>
          <p class="card-excerpt">{latestSummary.summaryEn}</p>
          <div class="card-comment">
            <span class="comment-icon">💡</span>
            {latestSummary.commentEn}
          </div>
        </a>

        <!-- BanbaiGuan -->
        <a href={`/en/banbaiguan/${latestArticle.slug}/`} class="grid-card card-article">
          <div class="card-label">
            <span class="label-icon">🎯</span>
            <span class="label-text">BanbaiGuan AI</span>
          </div>
          <div class="card-date">{latestArticle.date}</div>
          <h3 class="card-heading">{latestArticle.titleEn}</h3>
          <p class="card-excerpt">{latestArticle.excerptEn}</p>
        </a>
      </div>
    </div>
  </section>

  <!-- AI Projects -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">AI Projects</div>
      <div class="placeholder-card">
        <p>Coming soon <span class="placeholder-dots">· · ·</span></p>
      </div>
    </div>
  </section>

  <!-- About Company -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">About the Company</div>
      <div class="company-card">
        <div class="company-badge">National High-Tech Enterprise</div>
        <h2>MonolithIoT (Changzhou) Co., Ltd.</h2>
        <p class="company-desc">An AI scenario solutions provider. Built on three core technologies: multi-sensor fusion, AI-powered storage middleware, and multimodal algorithms — digitizing the entire industrial chain.</p>
        <div class="company-clients">
          <span class="client-label">Trusted by</span>
          <span class="client-name">State Grid</span>
          <span class="client-name">Huawei</span>
          <span class="client-name">SF Express</span>
          <span class="client-name">DHL</span>
        </div>
        <div class="company-actions">
          <a href="/en/about/" class="link-arrow">Learn More</a>
          <a href="https://www.monolithiot.com" class="link-arrow" target="_blank" rel="noopener">Visit Company Site →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Follow Section -->
  <section class="follow-section">
    <div class="container">
      <div class="section-title" style="text-align: center;">Follow Us</div>
      <p class="follow-subtitle">Search "BanbaiGuan AI" on all platforms to find us</p>
      <div class="follow-qr-codes">
        <div class="follow-qr-item">
          <img src="/gzh-qr.jpg" alt="WeChat BanbaiGuan AI" loading="lazy" />
          <span class="follow-qr-label">WeChat</span>
        </div>
        <div class="follow-qr-item">
          <img src="/dy-qr.jpg" alt="Video Account BanbaiGuan AI" loading="lazy" />
          <span class="follow-qr-label">Video Account</span>
        </div>
        <div class="follow-qr-item">
          <img src="/douyin-qr.jpg" alt="Douyin BanbaiGuan AI" loading="lazy" />
          <span class="follow-qr-label">Douyin</span>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero 动画时序 — 其余样式已由 global.css 提供 */
  .hero-eyebrow { animation: fadeInUp 0.6s ease forwards; animation-delay: 0.1s; }
  .hero-title { animation: fadeInUp 0.8s ease forwards; animation-delay: 0.2s; }
  .hero-subtitle { animation: fadeInUp 0.8s ease forwards; animation-delay: 0.35s; }
  .hero-description { animation: fadeInUp 0.8s ease forwards; animation-delay: 0.5s; }
  .hero-actions { animation: fadeInUp 0.8s ease forwards; animation-delay: 0.65s; }
  .hero-scroll-hint { animation: fadeIn 0.6s ease forwards; animation-delay: 1.2s; }

  .btn-arrow { transition: transform 0.2s; }
  .btn-primary:hover .btn-arrow { transform: translateX(4px); }
</style>
