---
import BaseLayout from '../../../layouts/Base.astro';
import { dailyNewsSummaries } from '../../../data/ai-news-summary';

const aiNewsJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "AI News Daily | Guanwu",
  "description": "Daily curated AI industry news — global trends, one minute to understand.",
  "url": "https://www.ban-bai.com/en/ai-news/",
  "author": {
    "@type": "Person",
    "name": "Mr. Wu",
    "alternateName": "Guanwu"
  },
  "publisher": {
    "@type": "Organization",
    "name": "MonolithIoT (Changzhou) Co., Ltd."
  }
};

const sortedNews = [...dailyNewsSummaries].sort((a, b) => b.date.localeCompare(a.date));
---

<BaseLayout title="AI News Daily | Guanwu" jsonLd={aiNewsJsonLd} ogDescription="Daily curated AI industry news — global trends, one minute to understand." navActive="ai-news" lang="en">
  <section class="page-section">
    <h1>AI News Daily</h1>
    <p class="subtitle" style="margin-bottom: 32px;">
      Global AI industry highlights — no noise, only key insights. Updated every morning 📰
    </p>
    <p style="font-size: 13px; color: var(--color-text-light); margin-bottom: 32px; font-style: italic;">
      💡 Auto-generated by AI assistant • Updated every morning at 7:00 AM
    </p>

    {sortedNews.length === 0 ? (
      <p class="empty-state">No news yet. Stay tuned! 📰</p>
    ) : (
      <div class="news-list">
        {sortedNews.map((day) => (
          <div class="news-card">
            <div class="news-date-header">{day.date}</div>
            <h2 class="news-title">{day.titleEn || day.title}</h2>
            <p class="news-summary">{day.summaryEn || day.summary}</p>
            {day.newsItems && day.newsItems.length > 0 && (
              <div class="news-items">
                {day.newsItems.map((item, i) => (
                  <div class="news-item">
                    <span class="news-item-num">{i + 1}</span>
                    <div class="news-item-content">
                      <strong>
                        {item.url ? (
                          <a href={item.url} target="_blank" rel="noopener noreferrer">{item.titleEn || item.title}</a>
                        ) : item.titleEn || item.title}
                      </strong>
                      <p>{item.summaryEn || item.summary}</p>
                      <div class="news-item-meta">
                        <span class="news-tag">{item.categoryEn || item.category}</span>
                        <span class="news-source">
                          {item.source}
                          {item.url && (
                            <a href={item.url} target="_blank" rel="noopener noreferrer" class="original-link"> → Original</a>
                          )}
                        </span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            )}
            {day.comment && (
              <div class="news-comment">
                💬 {day.comment}
              </div>
            )}
          </div>
        ))}
      </div>
    )}

    <div class="cta-section">
      <h2>Never Miss AI News</h2>
      <p>Follow Guanwu for daily AI industry updates</p>
      <div class="cta-links">
        <a href="/ai-news/" class="cta-link">🇨🇳 Chinese Version</a>
        <a href="/en/diary/" class="cta-link">📖 Daily Diary</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-section {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  .page-section h1 {
    font-family: var(--font-serif);
    font-size: 28px;
    margin-bottom: 8px;
  }
  .subtitle {
    font-size: 15px;
    color: var(--color-text-light);
  }
  .news-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .news-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 24px;
  }
  .news-date-header {
    font-size: 13px;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .news-title {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .news-summary {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .news-items {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 16px;
  }
  .news-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .news-item-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    background: var(--color-accent);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
  }
  .news-item-content strong {
    font-size: 15px;
    display: block;
    margin-bottom: 4px;
  }
  .news-item-content strong a {
    color: var(--color-text);
    text-decoration: none;
  }
  .news-item-content strong a:hover {
    color: var(--color-accent);
  }
  .news-item-content p {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0 0 8px;
  }
  .news-item-meta {
    display: flex;
    gap: 12px;
    font-size: 12px;
    color: var(--color-text-light);
    align-items: center;
  }
  .original-link {
    color: var(--color-accent);
    text-decoration: none;
    margin-left: 4px;
  }
  .original-link:hover {
    text-decoration: underline;
  }
  .news-tag {
    padding: 2px 8px;
    background: var(--color-bg);
    border-radius: 4px;
  }
  .news-comment {
    padding: 12px 16px;
    background: var(--color-bg);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
    font-size: 14px;
    font-style: italic;
  }
  .cta-section {
    text-align: center;
    padding: 40px 20px;
    margin-top: 32px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }
  .cta-section h2 {
    font-size: 22px;
    margin-bottom: 8px;
  }
  .cta-section p {
    color: var(--color-text-light);
    margin-bottom: 20px;
  }
  .cta-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta-link {
    padding: 10px 20px;
    background: var(--color-accent);
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
  }
  .cta-link:hover {
    opacity: 0.9;
  }
  .empty-state {
    text-align: center;
    color: var(--color-text-light);
    padding: 60px 20px;
  }
</style>
