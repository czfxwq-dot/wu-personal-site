const diaryJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "Day 9：对话终于通了，但临时方案终究要还债",
  "datePublished": "2026-05-06",
  "dateModified": "2026-05-06",
  "author": {
    "@type": "Person",
    "name": "吴总",
    "alternateName": "观吾"
  }
