    align-items: center;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .diary-header time {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 500;
  }
  .diary-day {
    font-size: 13px;
    color: var(--color-text-light);
  }
  .diary-content h3 {
    font-family: var(--font-serif);
    font-size: 20px;
    margin: 32px 0 16px;
    color: var(--color-text);
  }
  .diary-content p {
    font-size: 15px;
    line-height: 1.9;
    margin-bottom: 16px;
  }
  .diary-content strong {
    color: var(--color-accent);
  }
