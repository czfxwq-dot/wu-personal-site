---
import BaseLayout from '../../layouts/Base.astro';
import { promises as fs } from 'fs';
import path from 'path';

const guestbookJsonLd = {
  "@context": "https://schema.org",
  "@type": "DiscussionForumPosting",
  "name": "留言板 | 观吾",
  "description": "给观吾留言 — AI 会自动回复你的每一条留言",
  "url": "https://ban-bai.com/guestbook/"
};

// 读取留言数据（构建时静态生成）
let messages: any[] = [];
try {
  const DATA_FILE = path.resolve('./src/data/guestbook.json');
  const raw = await fs.readFile(DATA_FILE, 'utf-8');
  messages = JSON.parse(raw).reverse();
} catch {}

function formatDate(iso: string): string {
  const d = new Date(iso);
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
}
---

<BaseLayout title="留言板 | 给观吾留言 - AI自动回复" jsonLd={guestbookJsonLd} ogDescription="给观吾（吴总）留言 — AI 会自动回复你的每一条留言，分享你的想法或提问" navActive="guestbook">
  <section class="page-section">
    <h1>留言板</h1>
    <p class="subtitle" style="margin-bottom: 8px;">
      给观吾留句话，AI 会自动回复你 ✍️
    </p>
    <p style="font-size: 13px; color: var(--color-text-light); margin-bottom: 32px; font-style: italic;">
      <span class="info-icon" style="display:inline-block;width:16px;height:16px;border:1px solid var(--color-border);border-radius:50%;text-align:center;line-height:14px;font-size:10px;margin-right:4px;font-style:normal;">i</span>
      完全自主运营，不依赖任何第三方平台
    </p>

    <!-- 留言表单 -->
    <div class="guestbook-form-card">
      <h3 style="margin-bottom: 16px;"><span class="form-icon">✎</span> 写留言</h3>
      <form id="guestbook-form">
        <div class="form-group">
          <label for="gb-name">你的名字</label>
          <input type="text" id="gb-name" name="name" placeholder="怎么称呼你？" required maxlength="20" />
        </div>
        <div class="form-group">
          <label for="gb-email">邮箱（可选，用于接收回复）</label>
          <input type="email" id="gb-email" name="email" placeholder="example@email.com" />
        </div>
        <div class="form-group">
          <label for="gb-content">留言内容</label>
          <textarea id="gb-content" name="content" rows="4" placeholder="想说点什么？" required maxlength="500"></textarea>
          <span class="char-count"><span id="char-count">0</span>/500</span>
        </div>
        <button type="submit" id="submit-btn" class="submit-btn">
          <span class="btn-text">提交留言</span>
          <span class="btn-loading" style="display: none;">提交中...</span>
        </button>
      </form>
      <div id="form-success" class="success-msg" style="display: none;">
        <span class="success-icon">✓</span> 留言成功！AI 助理会尽快回复你
      </div>
      <div id="form-error" class="error-msg" style="display: none;"></div>
    </div>

    <!-- 留言列表（静态渲染） -->
    <div style="margin-top: 40px;">
      <h3 style="margin-bottom: 20px;"><span class="msg-icon">◈</span> 往期留言</h3>
      {messages.length === 0 ? (
        <p class="empty-state">还没有留言，来做第一个吧</p>
      ) : (
        messages.map((msg) => (
          <div class="message-card">
            <div class="message-header">
              <span class="message-author">{msg.name}</span>
              <span class="message-date">{formatDate(msg.createdAt)}</span>
            </div>
            <p class="message-content">{msg.content}</p>
            {msg.reply && (
              <div class="message-reply">
                <strong>AI 回复：</strong>{msg.reply}
              </div>
            )}
          </div>
        ))
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .guestbook-form-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 24px;
    max-width: 600px;
  }
  .form-icon, .msg-icon {
    display: inline-block;
    font-size: 16px;
    font-style: normal;
    color: var(--color-accent);
    margin-right: 6px;
    font-weight: 700;
  }
  .success-msg {
    margin-top: 16px;
    padding: 12px 16px;
    background: rgba(34, 197, 94, 0.1);
    border-radius: 8px;
    color: var(--color-success);
    font-size: 14px;
  }
  .form-group {
    margin-bottom: 16px;
  }
  .form-group label {
    display: block;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 6px;
    color: var(--color-text);
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    background: var(--color-bg);
    color: var(--color-text);
    box-sizing: border-box;
    transition: border-color 0.2s;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .form-group textarea {
    resize: vertical;
  }
  .char-count {
    display: block;
    text-align: right;
    font-size: 12px;
    color: var(--color-text-light);
    margin-top: 4px;
  }
  .submit-btn {
    display: block;
    width: 100%;
    padding: 12px 24px;
    background: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .submit-btn:hover {
    opacity: 0.9;
  }
  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .success-msg {
    margin-top: 16px;
    padding: 12px 16px;
    background: #e6f7e6;
    border-radius: 8px;
    color: #2d7d2d;
    font-size: 14px;
  }
  .error-msg {
    margin-top: 16px;
    padding: 12px 16px;
    background: #fde8e8;
    border-radius: 8px;
    color: #c0392b;
    font-size: 14px;
  }
  .message-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
  }
  .message-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  .message-author {
    font-weight: 600;
    font-size: 14px;
  }
  .message-date {
    font-size: 12px;
    color: var(--color-text-light);
  }
  .message-content {
    font-size: 14px;
    line-height: 1.7;
    margin-bottom: 12px;
  }
  .message-reply {
    padding: 12px 16px;
    background: var(--color-bg);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
    font-size: 14px;
    color: var(--color-text);
  }
  .message-reply strong {
    font-weight: 600;
  }
  .empty-state {
    text-align: center;
    color: var(--color-text-light);
    padding: 40px;
  }
</style>

<script>
  function formatDate(iso: string): string {
    const d = new Date(iso);
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')} ${String(d.getHours()).padStart(2, '0')}:${String(d.getMinutes()).padStart(2, '0')}`;
  }

  // 字符计数
  const contentInput = document.getElementById('gb-content') as HTMLTextAreaElement;
  const charCount = document.getElementById('char-count');
  contentInput?.addEventListener('input', () => {
    if (charCount) charCount.textContent = contentInput.value.length;
  });

  // 提交表单
  const form = document.getElementById('guestbook-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = submitBtn?.querySelector('.btn-text') as HTMLElement;
  const btnLoading = submitBtn?.querySelector('.btn-loading') as HTMLElement;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e: Event) => {
    e.preventDefault();
    
    submitBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline';
    successMsg.style.display = 'none';
    errorMsg.style.display = 'none';

    const formData = new FormData(form);
    const data = {
      name: formData.get('name'),
      content: formData.get('content'),
      email: formData.get('email') || '',
    };

    try {
      const res = await fetch('/api/guestbook', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok && result.success) {
        successMsg.style.display = 'block';
        form.reset();
        if (charCount) charCount.textContent = '0';
      } else {
        errorMsg.textContent = result.error || '提交失败，请稍后重试';
        errorMsg.style.display = 'block';
      }
    } catch {
      errorMsg.textContent = '网络错误，请稍后重试';
      errorMsg.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      btnText.style.display = 'inline';
      btnLoading.style.display = 'none';
    }
  });
</script>
