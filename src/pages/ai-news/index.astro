---
import BaseLayout from '../../layouts/Base.astro';
import { dailyNewsSummaries } from '../../data/ai-news-summary';

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  const weekdays = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
  return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日 ${weekdays[d.getDay()]}`;
}

const newsJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "AI新闻 | 观吾",
  "description": "每天AI行业重大新闻汇总 + 一句话点评",
  "url": "https://ban-bai.com/ai-news/",
  "author": {
    "@type": "Person",
    "name": "吴总",
    "alternateName": "观吾"
  },
  "publisher": {
    "@type": "Organization",
    "name": "磐石电气（常州）有限公司"
  }
};

const allDates = dailyNewsSummaries.map(d => d.date);
---

<BaseLayout title="AI新闻 | 每天AI行业重大新闻汇总 - 观吾" jsonLd={newsJsonLd} ogDescription="每天AI行业重大新闻汇总 + 一句话点评，覆盖大模型、硬件、产业、投资、政策等方向" navActive="ai-news">
  <section class="page-section">
    <h1>AI新闻</h1>
    <p class="subtitle">
      每天AI行业重大新闻汇总 + 一句话点评
    </p>

    <!-- 搜索+日期筛选栏 -->
    <div class="search-bar">
      <div class="search-input-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <input type="text" id="news-search" class="search-input" placeholder="搜索新闻标题或内容..." />
      </div>
      <select id="news-date-filter" class="date-filter">
        <option value="">全部日期</option>
        {allDates.map(d => <option value={d}>{d}</option>)}
      </select>
      <select id="news-category-filter" class="date-filter">
        <option value="">全部类别</option>
        <option value="大模型">大模型</option>
        <option value="硬件">硬件</option>
        <option value="产业">产业</option>
        <option value="投资">投资</option>
        <option value="政策">政策</option>
        <option value="研究">研究</option>
        <option value="工具">工具</option>
      </select>
      <span id="news-count" class="result-count">共 {dailyNewsSummaries.length} 天</span>
    </div>

    <div id="news-list">
      {dailyNewsSummaries.map((day) => (
        <div class="news-day" data-date={day.date}
          data-search={`${day.title} ${day.summary} ${day.comment} ${day.newsItems.map(n => `${n.title} ${n.summary} ${n.source}`).join(' ')}`.toLowerCase()}>
          <div class="news-day-header">
            <time datetime={day.date}>{formatDate(day.date)}</time>
            <span class="news-count">{day.newsItems.length}条</span>
            <span class="read-time">{Math.max(1, Math.ceil(day.summary.length / 300))} min</span>
          </div>
          
          <h2 class="news-day-title">{day.title}</h2>
          <p class="news-day-summary">{day.summary}</p>
          
          <div class="news-items">
            {day.newsItems.map((item) => (
              <div class="news-item" data-category={item.category}
                data-item-search={`${item.title} ${item.summary} ${item.source}`.toLowerCase()}>
                <div class="news-item-header">
                  <span class="news-item-category" data-category={item.category}>{item.category}</span>
                  <h3>
                    {item.url ? (
                      <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                    ) : item.title}
                  </h3>
                </div>
                <p class="news-item-text">{item.summary}</p>
                <span class="news-item-source">
                  {item.source}
                  {item.url && (
                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="news-item-link"> → 原文</a>
                  )}
                </span>
              </div>
            ))}
          </div>

          {day.comment && (
            <div class="news-comment">
              <strong>📝 一句话点评：</strong>{day.comment}
            </div>
          )}
        </div>
      ))}
    </div>

    <div id="news-no-result" class="no-result" style="display:none;">
      <p>🔍 没有找到匹配的新闻</p>
    </div>

    <!-- GEO 优化：来源说明 -->
    <div class="sources-note">
      <h3>📰 新闻来源</h3>
      <p>AI新闻来源于以下权威渠道，每天精选并汇总：</p>
      <div class="sources-list">
        <a href="https://techcrunch.com/tag/artificial-intelligence/" target="_blank" rel="noopener">TechCrunch AI</a>
        <a href="https://www.theverge.com/ai-artificial-intelligence" target="_blank" rel="noopener">The Verge AI</a>
        <a href="https://venturebeat.com/category/ai/" target="_blank" rel="noopener">VentureBeat AI</a>
        <a href="https://www.wired.com/tag/artificial-intelligence/" target="_blank" rel="noopener">WIRED AI</a>
        <a href="https://36kr.com/" target="_blank" rel="noopener">36氪</a>
        <a href="https://www.jiqizhixin.com/" target="_blank" rel="noopener">机器之心</a>
        <a href="https://www.anthropic.com/news" target="_blank" rel="noopener">Anthropic News</a>
        <a href="https://openai.com/news" target="_blank" rel="noopener">OpenAI News</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-section {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  .page-section h1 {
    font-family: var(--font-serif);
    font-size: 28px;
    margin-bottom: 8px;
  }
  .subtitle {
    font-size: 15px;
    color: var(--color-text-light);
  }

  /* 搜索栏 */
  .search-bar {
    display: flex;
    gap: 10px;
    align-items: center;
    margin: 20px 0 24px;
    flex-wrap: wrap;
  }
  .search-input-wrap {
    flex: 1;
    min-width: 200px;
    position: relative;
  }
  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: var(--color-text-light);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 10px 12px 10px 38px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 14px;
    background: var(--color-card);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s;
  }
  .search-input:focus {
    border-color: var(--color-accent);
  }
  .date-filter {
    padding: 10px 12px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 14px;
    background: var(--color-card);
    color: var(--color-text);
    outline: none;
    cursor: pointer;
    white-space: nowrap;
  }
  .date-filter:focus {
    border-color: var(--color-accent);
  }
  .result-count {
    font-size: 13px;
    color: var(--color-text-light);
    white-space: nowrap;
  }

  .news-day {
    padding: 32px 20px;
    margin-bottom: 20px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }
  .news-day:last-child {
    margin-bottom: 0;
  }
  .news-day-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .news-day-header time {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-accent);
  }
  .news-count {
    font-size: 12px;
    padding: 2px 8px;
    background: var(--color-bg);
    border-radius: 4px;
    color: var(--color-text-light);
  }
  .read-time {
    font-size: 11px;
    color: var(--color-text-light);
    background: var(--color-bg);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .news-day-title {
    font-family: var(--font-serif);
    font-size: 20px;
    margin: 0 0 8px;
    line-height: 1.4;
  }
  .news-day-summary {
    font-size: 14px;
    color: var(--color-text-light);
    line-height: 1.7;
    margin: 0 0 20px;
  }
  .news-items {
    margin-bottom: 20px;
  }
  .news-item {
    padding: 16px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    margin-bottom: 12px;
  }
  .news-item-header {
    margin-bottom: 8px;
  }
  .news-item-category {
    font-size: 11px;
    padding: 2px 6px;
    color: #fff;
    border-radius: 3px;
    display: inline-block;
    margin-bottom: 6px;
  }
  .news-item-category[data-category="硬件"] {
    background: #f97316;
  }
  .news-item-category[data-category="大模型"] {
    background: #8b5cf6;
  }
  .news-item-category[data-category="产业"] {
    background: #0ea5e9;
  }
  .news-item-category[data-category="投资"] {
    background: #22c55e;
  }
  .news-item-category[data-category="政策"] {
    background: #ef4444;
  }
  .news-item-category[data-category="研究"] {
    background: #6366f1;
  }
  .news-item-category[data-category="工具"] {
    background: #14b8a6;
  }
  .news-item-header h3 {
    font-size: 15px;
    margin: 0;
    font-weight: 500;
  }
  .news-item-header h3 a {
    color: var(--color-text);
    text-decoration: none;
  }
  .news-item-header h3 a:hover {
    color: var(--color-accent);
  }
  .news-item-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0 0 8px;
  }
  .news-item-source {
    font-size: 12px;
    color: var(--color-text-light);
  }
  .news-item-link {
    color: var(--color-accent);
    text-decoration: none;
  }
  .news-item-link:hover {
    text-decoration: underline;
  }
  .news-comment {
    padding: 12px 16px;
    background: var(--color-bg);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
    font-size: 14px;
    line-height: 1.6;
  }
  .no-result {
    text-align: center;
    padding: 48px 20px;
    color: var(--color-text-light);
    font-size: 15px;
  }

  /* 新闻来源 */
  .sources-note {
    margin-top: 32px;
    padding: 20px;
    background: var(--color-bg);
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }
  .sources-note h3 {
    font-size: 15px;
    margin: 0 0 12px;
    color: var(--color-heading);
  }
  .sources-note p {
    font-size: 13px;
    color: var(--color-text-light);
    margin: 0 0 12px;
  }
  .sources-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .sources-list a {
    display: inline-block;
    padding: 4px 10px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 12px;
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.2s;
  }
  .sources-list a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>

<script>
  const searchInput = document.getElementById('news-search') as HTMLInputElement;
  const dateFilter = document.getElementById('news-date-filter') as HTMLSelectElement;
  const categoryFilter = document.getElementById('news-category-filter') as HTMLSelectElement;
  const newsList = document.getElementById('news-list')!;
  const noResult = document.getElementById('news-no-result')!;
  const countEl = document.getElementById('news-count')!;
  const days = newsList.querySelectorAll('.news-day') as NodeListOf<HTMLElement>;

  function filterNews() {
    const keyword = searchInput.value.trim().toLowerCase();
    const date = dateFilter.value;
    const category = categoryFilter.value;
    let visibleDays = 0;

    days.forEach(day => {
      const dayMatchDate = !date || day.dataset.date === date;

      const items = day.querySelectorAll('.news-item') as NodeListOf<HTMLElement>;
      let dayHasVisibleItem = false;

      items.forEach(item => {
        const itemMatchKeyword = !keyword || (item.dataset.itemSearch || '').includes(keyword);
        const itemMatchCategory = !category || item.dataset.category === category;
        const itemShow = itemMatchKeyword && itemMatchCategory;
        item.style.display = itemShow ? '' : 'none';
        if (itemShow) dayHasVisibleItem = true;
      });

      // 关键词搜索时也检查整日标题是否匹配（保证"一句话点评"可被搜索）
      const daySearchMatch = !keyword || (day.dataset.search || '').includes(keyword);
      const show = dayMatchDate && dayHasVisibleItem && daySearchMatch;
      day.style.display = show ? '' : 'none';
      if (show) visibleDays++;
    });

    noResult.style.display = visibleDays === 0 ? '' : 'none';
    countEl.textContent = `共 ${visibleDays} 天`;
  }

  searchInput.addEventListener('input', filterNews);
  dateFilter.addEventListener('change', filterNews);
  categoryFilter.addEventListener('change', filterNews);
</script>
