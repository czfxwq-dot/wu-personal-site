---
import BaseLayout from '../../layouts/Base.astro';


const pageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "云半百小龙虾 - 在线业务咨询",
  "description": "云半百小龙虾业务在线咨询服务，产品订购、加盟合作、售后支持一站式服务",
  "url": "https://ban-bai.com/lobster/"
};
---

<BaseLayout title="云半百小龙虾 - 在线业务咨询 | 观吾" jsonLd={pageJsonLd} ogDescription="云半百小龙虾业务在线咨询服务，产品订购、加盟合作、售后支持一站式服务" navActive="home">
  <section class="hero">
    <div class="container">
      <span class="hero-tag">🦞 云半百小龙虾</span>
      <h1>
        云半百小龙虾
        <span>新鲜·正宗·美味</span>
      </h1>
      <p class="subtitle">
        点击右下角🦞按钮，立即咨询我们的业务顾问<br />
        产品订购、加盟合作、售后支持，一站式在线服务
      </p>
    </div>
  </section>

  <!-- 业务板块 -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">我们的服务</div>
      
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon">🍤</div>
          <h3>产品订购</h3>
          <p>多种口味小龙虾，麻辣、蒜香、十三香...新鲜配送到家</p>
          <a href="#" class="service-link" onclick="openLobsterChat(event, '我想订购小龙虾，有什么口味？')">在线咨询 →</a>
        </div>
        
        <div class="service-card">
          <div class="service-icon">🤝</div>
          <h3>加盟合作</h3>
          <p>成熟的商业模式，完整的供应链支持，低门槛创业</p>
          <a href="#" class="service-link" onclick="openLobsterChat(event, '我想了解加盟政策')">了解详情 →</a>
        </div>
        
        <div class="service-card">
          <div class="service-icon">🚚</div>
          <h3>冷链配送</h3>
          <p>全程冷链保鲜，同城当日达，全国48小时送达</p>
          <a href="#" class="service-link" onclick="openLobsterChat(event, '你们的配送范围和时间是怎样的？')">查询配送 →</a>
        </div>
        
        <div class="service-card">
          <div class="service-icon">📋</div>
          <h3>售后支持</h3>
          <p>7天无理由退换，品质保证，24小时在线客服</p>
          <a href="#" class="service-link" onclick="openLobsterChat(event, '我需要售后服务')">联系售后 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 品牌介绍 -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">品牌故事</div>
      <div class="brand-story">
        <h2>云半百小龙虾</h2>
        <p>源自对品质的执着追求，每一只小龙虾都经过严格筛选，确保新鲜、安全、美味。我们致力于为消费者提供最优质的龙虾餐饮体验。</p>
        <div class="brand-stats">
          <div class="stat">
            <span class="stat-number">100%</span>
            <span class="stat-label">活虾现做</span>
          </div>
          <div class="stat">
            <span class="stat-number">24h</span>
            <span class="stat-label">在线客服</span>
          </div>
          <div class="stat">
            <span class="stat-number">7天</span>
            <span class="stat-label">无理由退换</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 在线对话提示 -->
  <section class="page-section chat-cta">
    <div class="container">
      <div class="cta-card">
        <h2>💬 需要帮助？</h2>
        <p>点击右下角的🦞按钮，与我们的AI业务顾问对话</p>
        <p class="cta-hint">支持产品咨询、订购引导、加盟合作、售后支持等</p>
      </div>
    </div>
  </section>

  
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 48px 0 32px;
    background: linear-gradient(135deg, #fef2f2 0%, #fff 100%);
  }
  .hero-tag {
    display: inline-block;
    font-size: 14px;
    padding: 4px 16px;
    background: #fee2e2;
    color: #dc2626;
    border-radius: 20px;
    margin-bottom: 16px;
  }
  .hero h1 {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #1a1a2e;
  }
  .hero h1 span {
    display: block;
    font-size: 16px;
    font-weight: 400;
    color: #dc2626;
    margin-top: 4px;
  }
  .subtitle {
    font-size: 16px;
    color: #6b7280;
    line-height: 1.6;
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin-top: 16px;
  }
  
  .service-card {
    background: white;
    border: 1px solid #fecaca;
    border-radius: 16px;
    padding: 24px;
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(220, 38, 38, 0.12);
  }
  .service-icon {
    font-size: 40px;
    margin-bottom: 12px;
  }
  .service-card h3 {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
    color: #1a1a2e;
  }
  .service-card p {
    font-size: 14px;
    color: #6b7280;
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .service-link {
    display: inline-block;
    font-size: 14px;
    color: #dc2626;
    text-decoration: none;
    font-weight: 500;
  }
  .service-link:hover {
    text-decoration: underline;
  }
  
  .brand-story {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }
  .brand-story h2 {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 12px;
    color: #dc2626;
  }
  .brand-story p {
    font-size: 16px;
    color: #4b5563;
    line-height: 1.7;
  }
  .brand-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-top: 24px;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stat-number {
    font-size: 28px;
    font-weight: 700;
    color: #dc2626;
  }
  .stat-label {
    font-size: 13px;
    color: #6b7280;
    margin-top: 4px;
  }
  
  .chat-cta {
    text-align: center;
  }
  .cta-card {
    background: linear-gradient(135deg, #fee2e2 0%, #fff 100%);
    border-radius: 16px;
    padding: 32px;
    max-width: 500px;
    margin: 0 auto;
  }
  .cta-card h2 {
    font-size: 22px;
    margin-bottom: 8px;
    color: #1a1a2e;
  }
  .cta-card p {
    font-size: 15px;
    color: #4b5563;
    margin-bottom: 4px;
  }
  .cta-hint {
    font-size: 13px;
    color: #9ca3af;
  }
  
  @media (max-width: 640px) {
    .brand-stats {
      gap: 20px;
    }
    .stat-number {
      font-size: 22px;
    }
  }
</style>

<script is:inline>
  function openLobsterChat(event, message) {
    event.preventDefault();
    var toggleBtn = document.getElementById('chat-toggle-btn');
    if (toggleBtn) {
      toggleBtn.click();
      setTimeout(function() {
        var input = document.getElementById('chat-input');
        var sendBtn = document.getElementById('chat-send-btn');
        if (input && sendBtn) {
          input.value = message;
          input.dispatchEvent(new Event('input'));
          setTimeout(function() {
            sendBtn.click();
          }, 300);
        }
      }, 400);
    }
  }
</script>
