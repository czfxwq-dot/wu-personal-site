---
import BaseLayout from '../layouts/Base.astro';
import { diaries } from '../data/diaries';
import { dailyNewsSummaries } from '../data/ai-news-summary';
import { articles } from '../data/articles';

const homeJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "观吾 | 50岁用AI做实事",
  "description": "50岁企业家用AI把想法变成现实 — 磐石电气联合创始人吴总的个人网站，记录AI项目落地全过程",
  "url": "https://banbai.ai",
  "isPartOf": {
    "@type": "WebSite",
    "name": "观吾",
    "url": "https://banbai.ai"
  },
  "about": {
    "@type": "Person",
    "name": "吴总",
    "alternateName": "观吾",
    "jobTitle": "联合创始人",
    "worksFor": {
      "@type": "Organization",
      "name": "磐石电气（常州）有限公司"
    }
  }
};

const latest = diaries[0];
const latestSummary = dailyNewsSummaries[0];
const latestArticle = articles[0];
---

<BaseLayout jsonLd={homeJsonLd} navActive="home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-gradient-1"></div>
      <div class="hero-gradient-2"></div>
      <div class="hero-grain"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        <span>AI 实践者 · 观吾</span>
      </div>
      <h1 class="hero-title">
        50岁，用AI<br/>把想法变成现实
      </h1>
      <p class="hero-subtitle">
        磐石电气联合创始人 · AIoT实践者 · 半百观AI主理人
      </p>
      <p class="hero-description">
        这不是一个普通的个人网站。<br/>
        它是我和我的AI助理一起，从0到1建造出来的。
      </p>
      <div class="hero-actions">
        <a href="/diary/" class="btn btn-primary">看工作日记 <span class="btn-arrow">→</span></a>
        <a href="/about/" class="btn btn-ghost">了解更多</a>
      </div>
    </div>
    <div class="hero-scroll-hint">
      <span class="scroll-line"></span>
      <span class="scroll-text">向下滚动</span>
    </div>
  </section>

  <!-- 内容网格 — 三栏并排 -->
  <section class="content-grid">
    <div class="container">
      <div class="grid-header">
        <div class="section-title">最近更新</div>
        <span class="section-more">查看完整时间线 <span class="arrow">→</span></span>
      </div>
      <div class="grid-cards">
        <!-- 最新日记 -->
        <a href="/diary/" class="grid-card card-diary">
          <div class="card-label">
            <span class="label-icon">📓</span>
            <span class="label-text">工作日记</span>
          </div>
          <div class="card-date">{latest.date}</div>
          <h3 class="card-heading">{latest.title}</h3>
          <p class="card-excerpt">{latest.summary}</p>
        </a>

        <!-- AI新闻 -->
        <a href="/ai-news/" class="grid-card card-news">
          <div class="card-label">
            <span class="label-icon">📡</span>
            <span class="label-text">AI 新闻</span>
          </div>
          <div class="card-date">{latestSummary.date} · {latestSummary.newsItems.length} 条</div>
          <h3 class="card-heading">{latestSummary.title}</h3>
          <p class="card-excerpt">{latestSummary.summary}</p>
          <div class="card-comment">
            <span class="comment-icon">💡</span>
            {latestSummary.comment}
          </div>
        </a>

        <!-- 半百观 -->
        <a href={`/banbaiguan/${latestArticle.slug}/`} class="grid-card card-article">
          <div class="card-label">
            <span class="label-icon">🎯</span>
            <span class="label-text">半百观AI</span>
          </div>
          <div class="card-date">{latestArticle.date}</div>
          <h3 class="card-heading">{latestArticle.title}</h3>
          <p class="card-excerpt">{latestArticle.excerpt}</p>
        </a>
      </div>
    </div>
  </section>

  <!-- AI项目 -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">AI 项目</div>
      <div class="placeholder-card">
        <p>内容建设中，敬请期待...</p>
      </div>
    </div>
  </section>

  <!-- 关于公司 -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">关于公司</div>
      <div class="company-card">
        <div class="company-badge">国家级高新技术企业</div>
        <h2>磐石电气（常州）有限公司</h2>
        <p class="company-desc">精准定位AI场景解决方案提供商。依托多传感器融合、智慧存储AI中台、多模态算法三大核心技术，打通场景数智化全链路。</p>
        <div class="company-clients">
          <span class="client-label">长期服务</span>
          <span class="client-name">国家电网</span>
          <span class="client-name">华为</span>
          <span class="client-name">顺丰</span>
          <span class="client-name">DHL</span>
        </div>
        <div class="company-actions">
          <a href="/about/" class="link-arrow">了解更多</a>
          <a href="https://www.monolithiot.com" class="link-arrow" target="_blank" rel="noopener">访问公司官网 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 关注扫码 -->
  <section class="follow-section">
    <div class="container">
      <div class="section-title" style="text-align: center;">关注我们</div>
      <p class="follow-subtitle">在各平台搜索「半百观AI」即可找到我们</p>
      <div class="follow-qr-codes">
        <div class="follow-qr-item">
          <img src="/gzh-qr.jpg" alt="公众号 半百观AI" />
          <span class="follow-qr-label">公众号</span>
        </div>
        <div class="follow-qr-item">
          <img src="/dy-qr.jpg" alt="视频号 半百观AI" />
          <span class="follow-qr-label">视频号</span>
        </div>
        <div class="follow-qr-item">
          <img src="/douyin-qr.jpg" alt="抖音 半百观AI" />
          <span class="follow-qr-label">抖音</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 公司公众号二维码弹窗 -->
  <div class="qr-modal-overlay" id="qr-modal-overlay">
    <div class="qr-modal">
      <button class="qr-modal-close" id="close-qr-modal">✕</button>
      <h3 class="qr-modal-title">扫码咨询业务合作</h3>
      <p class="qr-modal-subtitle">关注磐石电气公众号，获取专业方案</p>
      <img src="/wechat-qr.jpg" alt="磐石电气 公众号二维码" class="qr-modal-img" />
      <p class="qr-modal-hint">长按识别图中二维码</p>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var trigger = document.getElementById('open-qr-modal');
      var overlay = document.getElementById('qr-modal-overlay');
      var closeBtn = document.getElementById('close-qr-modal');
      if (trigger && overlay) {
        trigger.addEventListener('click', function() {
          overlay.classList.add('active');
        });
      }
      if (closeBtn && overlay) {
        closeBtn.addEventListener('click', function() {
          overlay.classList.remove('active');
        });
      }
      if (overlay) {
        overlay.addEventListener('click', function(e) {
          if (e.target === overlay) {
            overlay.classList.remove('active');
          }
        });
      }
    });
  </script>
</BaseLayout>

<style>
  /* ===================================================
     Hero Section
     =================================================== */
  .hero {
    position: relative;
    padding: 100px 0 80px;
    overflow: hidden;
    min-height: 75vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* 背景纹理 */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-gradient-1 {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(45, 53, 97, 0.06) 0%, transparent 70%);
    border-radius: 50%;
  }

  .hero-gradient-2 {
    position: absolute;
    bottom: -30%;
    left: -15%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(200, 164, 92, 0.05) 0%, transparent 70%);
    border-radius: 50%;
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 150px;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    animation: fadeInUp 0.8s ease forwards;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
    margin-bottom: 28px;
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: 0.1s;
    opacity: 0;
  }

  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-gold);
    animation: pulse 2s ease-in-out infinite;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: 20px;
    animation: fadeInUp 0.8s ease forwards;
    animation-delay: 0.2s;
    opacity: 0;
  }

  .hero-subtitle {
    font-size: 16px;
    color: var(--color-gold);
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-bottom: 16px;
    animation: fadeInUp 0.8s ease forwards;
    animation-delay: 0.35s;
    opacity: 0;
  }

  .hero-description {
    font-size: 17px;
    color: var(--color-text-secondary);
    line-height: 1.8;
    max-width: 520px;
    margin-bottom: 32px;
    animation: fadeInUp 0.8s ease forwards;
    animation-delay: 0.5s;
    opacity: 0;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    animation: fadeInUp 0.8s ease forwards;
    animation-delay: 0.65s;
    opacity: 0;
  }

  .btn-arrow {
    transition: transform 0.2s;
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: fadeIn 0.6s ease forwards;
    animation-delay: 1.2s;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .scroll-line::after {
    content: '';
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-gold);
    animation: scrollDown 2s ease-in-out infinite;
  }

  @keyframes scrollDown {
    0% { top: -100%; }
    50% { top: 100%; }
    100% { top: 100%; }
  }

  .scroll-text {
    font-size: 11px;
    color: var(--color-text-tertiary);
    letter-spacing: 0.1em;
  }

  /* ===================================================
     内容网格
     =================================================== */
  .content-grid {
    padding: 48px 0;
  }

  .grid-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
  }

  .section-more {
    font-size: 13px;
    color: var(--color-text-tertiary);
    cursor: pointer;
    transition: color 0.2s;
  }

  .section-more:hover {
    color: var(--color-accent);
  }

  .section-more .arrow {
    transition: transform 0.2s;
    display: inline-block;
  }

  .section-more:hover .arrow {
    transform: translateX(4px);
  }

  .grid-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .grid-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .grid-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .card-diary::before { background: var(--color-accent); }
  .card-news::before { background: var(--color-gold); }
  .card-article::before { background: linear-gradient(90deg, var(--color-accent), var(--color-gold)); }

  .grid-card:hover {
    border-color: transparent;
    box-shadow: var(--shadow-lg);
    transform: translateY(-6px);
  }

  .grid-card:hover::before {
    opacity: 1;
  }

  .card-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }

  .label-icon {
    font-size: 18px;
    line-height: 1;
  }

  .label-text {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
  }

  .card-date {
    font-size: 13px;
    color: var(--color-text-tertiary);
    margin-bottom: 10px;
  }

  .card-heading {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text);
    margin-bottom: 10px;
    transition: color 0.2s;
  }

  .grid-card:hover .card-heading {
    color: var(--color-accent);
  }

  .card-excerpt {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 0;
  }

  .card-comment {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-top: 14px;
    padding: 12px 14px;
    background: rgba(200, 164, 92, 0.06);
    border-radius: var(--radius-sm);
    font-size: 13px;
    color: var(--color-text);
    line-height: 1.5;
  }

  .comment-icon {
    font-size: 14px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ===================================================
     公司卡片
     =================================================== */
  .company-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: 36px;
  }

  .company-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    background: rgba(45, 53, 97, 0.06);
    padding: 4px 12px;
    border-radius: var(--radius-full);
    margin-bottom: 16px;
  }

  .company-card h2 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .company-desc {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .company-clients {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .client-label {
    font-size: 12px;
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .client-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text);
    background: var(--color-bg-alt);
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }

  .company-actions {
    display: flex;
    gap: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border-light);
  }

  /* ===================================================
     关注板块
     =================================================== */
  .follow-section {
    text-align: center;
    padding: 60px 0;
    background: var(--color-bg-alt);
    border-radius: var(--radius-lg);
    margin-bottom: 64px;
  }

  .follow-subtitle {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-bottom: 32px;
  }

  .follow-qr-codes {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .follow-qr-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    transition: transform 0.2s;
  }

  .follow-qr-item:hover {
    transform: translateY(-4px);
  }

  .follow-qr-item img {
    width: 130px;
    height: 130px;
    border-radius: var(--radius-md);
    object-fit: cover;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
  }

  .follow-qr-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  /* ===================================================
     占位卡片
     =================================================== */
  .placeholder-card {
    background: transparent;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
    padding: 40px;
  }

  .placeholder-card p {
    color: var(--color-text-tertiary);
    font-size: 15px;
  }

  /* ===================================================
     二维码弹窗
     =================================================== */
  .qr-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .qr-modal-overlay.active {
    display: flex;
  }

  .qr-modal {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 36px 28px 28px;
    max-width: 380px;
    width: 90%;
    text-align: center;
    position: relative;
    box-shadow: var(--shadow-lg);
    animation: modalIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes modalIn {
    from { transform: scale(0.95) translateY(10px); opacity: 0; }
    to { transform: scale(1) translateY(0); opacity: 1; }
  }

  .qr-modal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: var(--color-text-tertiary);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.2s;
  }

  .qr-modal-close:hover {
    background: var(--color-bg-alt);
  }

  .qr-modal-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .qr-modal-subtitle {
    font-size: 14px;
    color: var(--color-text-secondary);
    margin-bottom: 20px;
  }

  .qr-modal-img {
    width: 300px;
    height: 300px;
    object-fit: contain;
    border-radius: var(--radius-md);
  }

  .qr-modal-hint {
    font-size: 12px;
    color: var(--color-text-tertiary);
    margin-top: 14px;
  }

  /* ===================================================
     响应式
     =================================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 80px 0 60px;
      min-height: auto;
    }

    .hero-title {
      font-size: 32px;
    }

    .hero-scroll-hint {
      display: none;
    }

    .grid-cards {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .grid-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .company-card {
      padding: 24px;
    }

    .follow-section {
      padding: 40px 0;
      margin-bottom: 48px;
    }

    .follow-qr-item img {
      width: 110px;
      height: 110px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 60px 0 48px;
    }

    .hero-title {
      font-size: 28px;
    }

    .hero-description {
      font-size: 15px;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .grid-card {
      padding: 22px;
    }

    .company-card h2 {
      font-size: 20px;
    }

    .company-actions {
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
