---
import BaseLayout from '../layouts/Base.astro';
import { diaries } from '../data/diaries';
import { dailyNewsSummaries } from '../data/ai-news-summary';
import { articles } from '../data/articles';

const homeJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "观吾 | 50岁用AI做实事 — AI工具落地实践 · 半百观AI",
  "description": "观吾，不只是一个人的网站——这是我和AI助理共同成长、共同学习的记录，也是50岁的创业者吴总借助AI把想法变成现实的真实故事",
  "url": "https://ban-bai.com",
  "isPartOf": {
    "@type": "WebSite",
    "name": "观吾",
    "url": "https://ban-bai.com"
  },
  "about": {
    "@type": "Person",
    "name": "吴总",
    "alternateName": "观吾",
    "jobTitle": "联合创始人",
    "worksFor": {
      "@type": "Organization",
      "name": "磐石电气（常州）有限公司"
    }
  },
  "keywords": ["AI工具", "AI落地实践", "半百观AI", "AIoT", "数字化智能库存", "50岁学AI", "ChatGPT教程", "AI效率提升"]
};

const latest = diaries[0];
const latestSummary = dailyNewsSummaries[0];
const latestArticle = articles[0];
---

<BaseLayout title="观吾 | 50岁用AI做实事 — AI工具落地实践" jsonLd={homeJsonLd} ogDescription="观吾，不只是一个人的网站——这是我和AI助理共同成长、共同学习的记录，也是50岁的创业者借助AI把想法变成现实的真实故事" navActive="home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-gradient-1"></div>
      <div class="hero-gradient-2"></div>
      <div class="hero-grain"></div>
    </div>
    <div class="container hero-content">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        <span>AI 实践者 · 半百观AI主理人</span>
      </div>
      <h1 class="hero-title">
        50岁，用AI<br/>把想法变成现实
      </h1>
      <p class="hero-subtitle">
        磐石电气联合创始人 · AIoT实践者 · 半百观AI主理人
      </p>
      <p class="hero-description">
        观吾，不只是一个人的网站——<br/>
        这是我和AI助理共同成长、共同学习的记录，<br/>
        也是我想与你分享的：一个50岁的创业者，如何借助AI把想法变成现实。
      </p>
      <div class="hero-actions">
        <a href="/diary/" class="btn btn-primary">看工作日记 <span class="btn-arrow">→</span></a>
        <button class="btn btn-accent" id="hero-chat-btn">💬 和 AI 助理聊聊</button>
        <a href="/about/" class="btn btn-ghost">了解更多</a>
      </div>
    </div>
    <div class="hero-scroll-hint">
      <span class="scroll-line"></span>
      <span class="scroll-text">向下滚动</span>
    </div>
  </section>

  <!-- 内容网格 — 三栏并排 -->
  <section class="content-grid">
    <div class="container">
      <div class="grid-header">
        <div class="section-title">最近更新</div>
        <a href="/diary/" class="section-more">查看完整时间线 <span class="arrow">→</span></a>
      </div>
      <div class="grid-cards">
        <!-- 最新日记 -->
        <a href="/diary/" class="grid-card card-diary">
          <div class="card-label">
            <span class="label-icon">📓</span>
            <span class="label-text">工作日记</span>
          </div>
          <div class="card-date">{latest.date}</div>
          <h3 class="card-heading">{latest.title}</h3>
          <p class="card-excerpt">{latest.summary}</p>
        </a>

        <!-- AI新闻 -->
        <a href="/ai-news/" class="grid-card card-news">
          <div class="card-label">
            <span class="label-icon">📡</span>
            <span class="label-text">AI 新闻</span>
          </div>
          <div class="card-date">{latestSummary.date} · {latestSummary.newsItems.length} 条</div>
          <h3 class="card-heading">{latestSummary.title}</h3>
          <p class="card-excerpt">{latestSummary.summary}</p>
          <div class="card-comment">
            <span class="comment-icon">💡</span>
            {latestSummary.comment}
          </div>
        </a>

        <!-- 半百观 -->
        <a href="/banbaiguan/" class="grid-card card-article">
          <div class="card-label">
            <span class="label-icon">🎯</span>
            <span class="label-text">半百观AI</span>
          </div>
          <div class="card-date">{latestArticle.date} · {articles.length} 篇</div>
          <h3 class="card-heading">{latestArticle.title}</h3>
          <p class="card-excerpt">{latestArticle.excerpt}</p>
        </a>
      </div>
    </div>
  </section>

  <!-- AI项目 -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">AI 项目</div>
      <div class="placeholder-card">
        <p>正在规划中，敬请期待 <span class="placeholder-dots">· · ·</span></p>
      </div>
    </div>
  </section>

  <!-- 关于公司 -->
  <section class="page-section">
    <div class="container">
      <div class="section-title">关于公司</div>
      <div class="company-card">
        <div class="company-badge">国家级高新技术企业</div>
        <h2>磐石电气（常州）有限公司</h2>
        <p class="company-desc">精准定位AI场景解决方案提供商。依托多传感器融合、智慧存储AI中台、多模态算法三大核心技术，打通场景数智化全链路。</p>
        <div class="company-clients">
          <span class="client-label">长期服务</span>
          <span class="client-name">国家电网</span>
          <span class="client-name">华为</span>
          <span class="client-name">顺丰</span>
          <span class="client-name">DHL</span>
        </div>
        <div class="company-actions">
          <a href="/about/" class="link-arrow">了解更多</a>
          <a href="https://www.monolithiot.com" class="link-arrow" target="_blank" rel="noopener">访问公司官网 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 关注扫码 — 第二层：半百观AI -->
  <section class="follow-section">
    <div class="container">
      <div class="section-title" style="text-align: center;">关注「半百观AI」</div>
      <p class="follow-subtitle">50岁视角看AI工具落地实践</p>
      <div class="follow-qr-codes">
        <div class="follow-qr-item">
          <img src="/gzh-qr.jpg" alt="微信公众号 半百观AI" width="430" height="430" loading="lazy" />
          <span class="follow-qr-label">微信公众号</span>
        </div>
        <div class="follow-qr-item">
          <img src="/dy-qr.jpg" alt="视频号 半百观AI" width="686" height="960" loading="lazy" />
          <span class="follow-qr-label">视频号</span>
        </div>
        <div class="follow-qr-item">
          <img src="/douyin-qr.jpg" alt="抖音 半百观AI" width="1125" height="1385" loading="lazy" />
          <span class="follow-qr-label">抖音</span>
        </div>
      </div>
      <p class="follow-search">也可在今日头条 · B站 · 西瓜视频 搜索「半百观AI」</p>
    </div>
  </section>


<script>
  // Inline chat for homepage
  (function() {
    const input = document.getElementById('inline-chat-input');
    const sendBtn = document.getElementById('inline-chat-send');
    const messages = document.getElementById('inline-chat-messages');
    if (!input || !sendBtn || !messages) return;

    let isTyping = false;

    function addMessage(text, type) {
      const msg = document.createElement('div');
      msg.className = 'chat-msg ' + type;
      msg.innerHTML = type === 'bot'
        ? '<span class="msg-avatar">🤖</span><div class="msg-bubble">' + text.replace(/\n/g, '<br/>') + '</div>'
        : '<span class="msg-avatar">👤</span><div class="msg-bubble">' + text + '</div>';
      messages.appendChild(msg);
      messages.scrollTop = messages.scrollHeight;
    }

    function showTyping() {
      isTyping = true;
      sendBtn.disabled = true;
      const msg = document.createElement('div');
      msg.className = 'chat-msg bot typing-indicator-wrap';
      msg.innerHTML = '<span class="msg-avatar">🤖</span><div class="msg-bubble"><div class="typing-indicator"><span></span><span></span><span></span></div></div>';
      messages.appendChild(msg);
      messages.scrollTop = messages.scrollHeight;
    }

    function hideTyping() {
      isTyping = false;
      sendBtn.disabled = false;
      const el = document.querySelector('.typing-indicator-wrap');
      if (el) el.remove();
    }

    async function send() {
      const text = input.value.trim();
      if (!text || isTyping) return;
      addMessage(text, 'user');
      input.value = '';
      showTyping();

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: text }),
        });
        hideTyping();

        // Handle SSE streaming
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let botReply = '';
        let buffer = '';

        // Create bot message bubble
        const msg = document.createElement('div');
        msg.className = 'chat-msg bot';
        msg.innerHTML = '<span class="msg-avatar">🤖</span><div class="msg-bubble"></div>';
        messages.appendChild(msg);
        const bubble = msg.querySelector('.msg-bubble');

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';
          for (const line of lines) {
            if (line.startsWith('data: ')) {
              const data = line.slice(6);
              if (data === '[DONE]') continue;
              try {
                const json = JSON.parse(data);
                const delta = json.choices?.[0]?.delta?.content;
                if (delta) {
                  botReply += delta;
                  bubble.innerHTML = botReply.replace(/\n/g, '<br/>');
                  messages.scrollTop = messages.scrollHeight;
                }
              } catch {}
            }
          }
        }

        if (!botReply) {
          bubble.textContent = '抱歉，我暂时无法回答。请稍后再试。';
        }
      } catch(e) {
        hideTyping();
        addMessage('网络错误，请稍后再试。', 'bot');
      }
    }

    sendBtn.addEventListener('click', send);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); send(); }
    });
  })();

  // Hero "和 AI 助理聊聊" button triggers floating chat
  (function() {
    const heroBtn = document.getElementById('hero-chat-btn');
    if (!heroBtn) return;
    heroBtn.addEventListener('click', function() {
      // Trigger existing ChatWidget toggle
      const toggleBtn = document.getElementById('chat-toggle-btn');
      if (toggleBtn) toggleBtn.click();
      else {
        // Fallback: scroll to inline chat
        const inlineChat = document.querySelector('.chat-inline');
        if (inlineChat) inlineChat.scrollIntoView({ behavior: 'smooth' });
      }
    });
  })();
</script>

</BaseLayout>

<style>
  /* Hero 动画时序 — 其余样式已由 global.css 提供 */
  .hero-eyebrow {
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: 0.1s;
  }

  .hero-title {
    animation: fadeInUp 0.8s ease forwards;
    animation-delay: 0.2s;
  }

  .hero-subtitle {
    animation: fadeInUp 0.8s ease forwards;
    animation-delay: 0.35s;
  }

  .hero-description {
    animation: fadeInUp 0.8s ease forwards;
    animation-delay: 0.5s;
  }

  .hero-actions {
    animation: fadeInUp 0.8s ease forwards;
    animation-delay: 0.65s;
  }

  .hero-scroll-hint {
    animation: fadeIn 0.6s ease forwards;
    animation-delay: 1.2s;
  }

  .btn-arrow {
    transition: transform 0.2s;
  }

  .btn-accent {
    background: #7c3aed;
    color: white;
    border: 2px solid #7c3aed;
    transition: background 0.15s, border-color 0.15s;
  }
  .btn-accent:hover {
    background: #6d28d9;
    border-color: #6d28d9;
  }
  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  /* 内联聊天区块 */
  .chat-inline {
    background: linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
    border-radius: 20px;
    margin: 0 auto;
    max-width: 800px;
    padding: 32px 24px;
  }

  .chat-inline-subtitle {
    text-align: center;
    color: var(--color-text-tertiary, #6b7280);
    font-size: 14px;
    margin-top: -8px;
    margin-bottom: 20px;
  }

  .chat-inline-box {
    background: white;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    overflow: hidden;
  }

  .chat-inline-messages {
    padding: 16px;
    max-height: 300px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .chat-msg {
    display: flex;
    gap: 8px;
    max-width: 85%;
    animation: msgIn 0.3s ease;
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .chat-msg.user {
    align-self: flex-end;
    flex-direction: row-reverse;
  }

  .chat-msg.bot {
    align-self: flex-start;
  }

  .msg-avatar {
    font-size: 18px;
    flex-shrink: 0;
  }

  .msg-bubble {
    padding: 10px 14px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.6;
    color: #333;
  }

  .chat-msg.bot .msg-bubble {
    background: #f3f4f6;
    border-top-left-radius: 4px;
  }

  .chat-msg.user .msg-bubble {
    background: #4f46e5;
    color: white;
    border-top-right-radius: 4px;
  }

  .chat-inline-input {
    display: flex;
    gap: 8px;
    padding: 12px;
    border-top: 1px solid #e5e7eb;
  }

  .chat-inline-input input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
    font-family: inherit;
  }

  .chat-inline-input input:focus {
    border-color: #4f46e5;
  }

  .chat-inline-input button {
    padding: 10px 20px;
    background: #4f46e5;
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    font-family: inherit;
  }

  .chat-inline-input button:hover {
    background: #4338ca;
  }

  .chat-inline-input button:disabled {
    background: #a5b4fc;
    cursor: not-allowed;
  }

  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 8px 0;
  }

  .typing-indicator span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #9ca3af;
    animation: typingDot 1.4s infinite;
  }

  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typingDot {
    0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-4px); }
  }

</style>
