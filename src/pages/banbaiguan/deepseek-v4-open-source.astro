---
// DeepSeek V4开源：万亿参数、百万token上下文，中国AI又放大招
const title = 'DeepSeek V4开源：万亿参数、百万token上下文，中国AI又放大招';
const date = '2026-05-11';
const summary = 'DeepSeek V4正式开源，两个版本（V4-Pro 1.6万亿参数、V4-Flash 2840亿参数），百万token上下文标配，MIT开源协议。对于中小企业来说，意味着企业知识库、代码辅助开发、智能客服升级都能用上了。技术民主化，这才是真正的革命。';
const keywords = ['DeepSeek', '开源', '大模型', '万亿参数', '百万token', '中小企业', '企业知识库', '技术民主化'];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | 半百观AI</title>
  <meta name="description" content={summary}>
  <meta name="keywords" content={keywords.join(',')}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={summary}>
