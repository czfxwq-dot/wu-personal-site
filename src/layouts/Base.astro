---
import '../styles/global.css';
import ChatWidget from '../components/ChatWidget.astro';

interface Props {
  title?: string;
  jsonLd?: object | object[];
  ogImage?: string;
  ogDescription?: string;
  navActive?: 'home' | 'diary' | 'ai-news' | 'banbaiguan' | 'guestbook' | 'about';
}

const { title = '观吾 | 50岁用AI做实事', jsonLd = [], ogImage, ogDescription, navActive } = Astro.props as Props;
// Google Analytics Measurement ID（在 Vercel 环境变量中配置 PUBLIC_GA_MEASUREMENT_ID）
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || '';

// 全局 JSON-LD（WebSite + Organization + Person + 半百观AI Blog）
const globalJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "观吾",
    "alternateName": ["banbai.ai", "观吾工作日记"],
    "url": "https://ban-bai.com",
    "description": "50岁企业家用AI把想法变成现实 — 磐石电气联合创始人吴总的个人网站",
    "inLanguage": "zh-CN",
    "potentialAction": {
      "@type": "ReadAction",
      "target": ["https://ban-bai.com/diary/", "https://ban-bai.com/ai-news/", "https://ban-bai.com/about/"]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "磐石电气（常州）有限公司",
    "alternateName": "MonolithIoT",
    "url": "https://www.monolithiot.com",
    "logo": "https://ban-bai.com/logo.png",
    "sameAs": [
      "https://www.youtube.com/channel/UC6x3JFjaUw3nMOen2PXDtsw"
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "吴总",
    "alternateName": "观吾",
    "jobTitle": "联合创始人",
    "worksFor": {
      "@type": "Organization",
      "name": "磐石电气（常州）有限公司"
    },
    "url": "https://ban-bai.com/about/",
    "description": "50岁，磐石电气联合创始人，专注数字化智能库存管理 AIoT 产品及解决方案，半百观AI主理人",
    "knowsAbout": ["AI应用", "AIoT", "数字化智能库存管理", "品牌管理", "新媒体运营"]
  },
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "半百观AI",
    "description": "50岁视角看AI工具落地实践 — AI工具、效率提升、商业落地真实分享",
    "url": "https://ban-bai.com/banbaiguan/",
    "author": {
      "@type": "Person",
      "name": "吴总",
      "url": "https://ban-bai.com/about/"
    },
    "publisher": {
      "@type": "Organization",
      "name": "磐石电气（常州）有限公司",
      "url": "https://www.monolithiot.com"
    },
    "inLanguage": "zh-CN",
    "keywords": ["AI工具", "AI落地", "效率提升", "商业AI", "AI实践"]
  }
];

const allJsonLd = Array.isArray(jsonLd) ? [...globalJsonLd, ...jsonLd] : [...globalJsonLd, jsonLd];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="50岁企业家用AI把想法变成现实 — 磐石电气联合创始人吴总的个人网站" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="author" content="观吾（吴总）" />
    <meta name="keywords" content="AI应用,AI工具,数字化智能库存,AIoT解决方案,磐石电气,智能货柜,无人仓库,线边仓,MRO智能柜,半百观AI,50岁用AI做实事" />
    {/* 国内搜索引擎优化 */}
    <meta name="shenma-site-verification" content={import.meta.env.PUBLIC_SHENMA_VERIFICATION || ""} />
    <meta name="sogou_site_verification" content={import.meta.env.PUBLIC_SOGOU_VERIFICATION || ""} />
    <meta name="360-site-verification" content={import.meta.env.PUBLIC_360_VERIFICATION || ""} />
    <link rel="canonical" href={Astro.url?.href || `https://ban-bai.com${Astro.url?.pathname || ''}`} />
    {/* Open Graph / 社交分享 */}
    <meta property="og:site_name" content="观吾" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription || "50岁企业家用AI把想法变成现实 — 磐石电气联合创始人吴总的个人网站"} />
    <meta property="og:image" content={ogImage || "https://ban-bai.com/og-image.png"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={Astro.url?.href || `https://ban-bai.com${Astro.url?.pathname || ''}`} />
    <meta property="og:locale" content="zh_CN" />
    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription || "50岁企业家用AI把想法变成现实"} />
    <meta name="twitter:image" content={ogImage || "https://ban-bai.com/og-image.png"} />
    {allJsonLd.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
    {gaId && (
      <>
        <!-- Google tag (gtag.js) -->
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '{gaId}');
        </script>
      </>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-brand">观吾</a>
        <nav class="site-nav">
          <a href="/" class:list={[navActive === 'home' && 'active']}>首页</a>
          <a href="/diary/" class:list={[navActive === 'diary' && 'active']}>日记</a>
          <a href="/ai-news/" class:list={[navActive === 'ai-news' && 'active']}>AI新闻</a>
          <a href="/banbaiguan/" class:list={[navActive === 'banbaiguan' && 'active']}>半百观</a>
          <a href="/guestbook/" class:list={[navActive === 'guestbook' && 'active']}>留言板</a>
          <a href="/about/" class:list={[navActive === 'about' && 'active']}>关于</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <!-- 第一层：联系磐石电气（常州）有限公司 -->
        <div class="footer-company">
          <p class="footer-company-title">联系磐石电气（常州）有限公司</p>
          <div class="footer-company-links">
            <a href="https://www.monolithiot.com" class="footer-link" target="_blank" rel="noopener">🏭 公司官网 →</a>
            <a href="https://www.youtube.com/channel/UC6x3JFjaUw3nMOen2PXDtsw" class="footer-link" target="_blank" rel="noopener">📺 YouTube →</a>
          </div>
          <div class="footer-company-qr">
            <img src="/company-qr.png" alt="磐石电气新媒体矩阵" loading="lazy" />
            <span class="footer-qr-hint">扫码查看公司新媒体矩阵</span>
          </div>
        </div>
        <div class="footer-bottom">
          <p class="footer-copy">© 2026 观吾 · ban-bai.com</p>
          <p class="footer-credit">这个网站由AI助理开发并维护</p>
        </div>
      </div>
    </footer>
    <ChatWidget />
    <style>
      .site-footer { background: var(--color-bg-alt); border-top: 1px solid var(--color-border); padding: 32px 0 24px; margin-top: 48px; }
      .footer-company { text-align: center; padding-bottom: 20px; border-bottom: 1px solid var(--color-border); margin-bottom: 16px; }
      .footer-company-title { font-family: var(--font-serif); font-size: 16px; font-weight: 600; margin-bottom: 16px; color: var(--color-text); }
      .footer-company-links { display: flex; justify-content: center; gap: 24px; margin-bottom: 20px; flex-wrap: wrap; }
      .footer-link { font-size: 14px; color: var(--color-accent); text-decoration: none; transition: opacity 0.2s; }
      .footer-link:hover { opacity: 0.7; }
      .footer-company-qr { display: flex; flex-direction: column; align-items: center; gap: 8px; }
      .footer-company-qr img { max-width: 360px; width: 100%; height: auto; border-radius: 12px; }
      .footer-qr-hint { font-size: 11px; color: var(--color-text-tertiary); }
      .footer-bottom { text-align: center; }
      .footer-copy { font-size: 11px; opacity: 0.5; margin: 0; }
      .footer-credit { font-size: 10px; opacity: 0.4; margin: 4px 0 0; }
      .footer-v { content: "v2026-05-09"; }
    </style>
  </body>
</html>
